{
  "enabled": true,
  "target_groups": [
    "123456789",
    "987654321"
  ],
  "sources": [
    "system_info",
    "countdown",
    "hitokoto"
  ],
  "interval": 60,
  "hourly_mode": false,
  "random_mode": true,
  "juhe_ckey": "",
  "alapi_token": "",
  "update_mode": "1",
  "signature_enabled": true,
  "signature_sources": [
    "hitokoto",
    "weibo_hot"
  ],
  "signature_interval": 3600,
  "signature_hourly_mode": false,
  "source_configs": [
    {
      "__template_key": "countdown",
      "target_date": "2027-01-01",
      "event_name": "元旦",
      "template": "{ev} {d}d {h}h {m}m"
    },
    {
      "__template_key": "countup",
      "target_date": "2024-01-01",
      "event_name": "开站",
      "template": "{ev} {y}y {m}m {d}d"
    },
    {
      "__template_key": "custom_text",
      "text": "在线 {time}"
    }
  ]
}
